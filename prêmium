local function tog(y,label)
    local row=mkF(M,Color3.fromRGB(14,6,28),UDim2.new(1,-16,0,30),UDim2.new(0,8,0,y),8)
    local rsk=Instance.new("UIStroke",row) rsk.Color=Color3.fromRGB(45,18,90) rsk.Thickness=1
    local bg=mkF(row,Color3.fromRGB(38,14,72),UDim2.new(0,44,0,22),UDim2.new(0,8,0.5,-11),20)
    local ci=mkF(bg,Color3.fromRGB(85,45,160),UDim2.new(0,18,0,18),UDim2.new(0,2,0,2),20)
    local btn=Instance.new("TextButton") btn.Size=UDim2.new(1,0,1,0) btn.BackgroundTransparency=1 btn.Text="" btn.Parent=bg
    local lb=mkL(row,label..": OFF",12,Color3.fromRGB(145,105,205),UDim2.new(0,60,0,0),UDim2.new(0,175,1,0))
    local ind=mkF(row,Color3.fromRGB(50,20,90),UDim2.new(0,7,0,7),UDim2.new(1,-18,0.5,-3.5),20)
    local function set(v)
        if v then
            TS:Create(ci,TweenInfo.new(0.15,Enum.EasingStyle.Quad),{Position=UDim2.new(0,24,0,2),BackgroundColor3=Color3.fromRGB(200,100,255)}):Play()
            TS:Create(bg,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(88,34,165)}):Play()
            TS:Create(ind,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(180,80,255)}):Play()
            lb.Text=label..": ON" lb.TextColor3=Color3.fromRGB(210,160,255)
        else
            TS:Create(ci,TweenInfo.new(0.15,Enum.EasingStyle.Quad),{Position=UDim2.new(0,2,0,2),BackgroundColor3=Color3.fromRGB(85,45,160)}):Play()
            TS:Create(bg,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(38,14,72)}):Play()
            TS:Create(ind,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(50,20,90)}):Play()
            lb.Text=label..": OFF" lb.TextColor3=Color3.fromRGB(145,105,205)
        end
    end
    return btn,set
end

