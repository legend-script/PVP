-- TOOL
local KEYS={"bastao","basto","stick","bat","taco","clube"}
local function isBat(n) n=string.lower(n) for _,k in ipairs(KEYS) do if string.find(n,k,1,true) then return true end end return false end
local function getEq()
    local ch=LP.Character if not ch then return nil end
    local hum=ch:FindFirstChildOfClass("Humanoid") if not hum then return nil end
    for _,v in ipairs(ch:GetChildren()) do if v:IsA("Tool") and isBat(v.Name) then return v end end
    local bp=LP:FindFirstChild("Backpack") if bp then for _,v in ipairs(bp:GetChildren()) do if v:IsA("Tool") and isBat(v.Name) then hum:EquipTool(v) task.wait(0.05) return v end end end
    for _,v in ipairs(ch:GetChildren()) do if v:IsA("Tool") then return v end end
    return nil
end
local function swing(tool,th)
    if not tool then return end
    pcall(function()
        for _,v in ipairs(tool:GetDescendants()) do if v:IsA("ClickDetector") then fireclickdetector(v) end end
        local h=tool:FindFirstChild("Handle") if h and th then firetouchinterest(h,th,0) task.wait(0.01) firetouchinterest(h,th,1) end
        tool:Activate()
    end)
end

-- BUSCA
local function findP(q,lbl)
    local ns={} for _,p in ipairs(Pl:GetPlayers()) do if p~=LP then table.insert(ns,p.Name) end end
    if #ns==0 then if lbl then lbl.Text="Sem jogadores" end return nil end
    q=string.gsub(q,"^%s*(.-)%s*$","%1")
    if #q<3 then if lbl then lbl.Text="Jogadores: "..table.concat(ns,", ") lbl.TextColor3=Color3.fromRGB(200,200,100) end return nil end
    local ql=string.lower(q)
    for _,p in ipairs(Pl:GetPlayers()) do if p~=LP and string.find(string.lower(p.Name),ql,1,true) then return p end end
    if lbl then lbl.Text="Jogadores: "..table.concat(ns,", ") lbl.TextColor3=Color3.fromRGB(255,180,50) end
    return nil
end

