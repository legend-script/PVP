    abC=RS.Heartbeat:Connect(function()
        if not S.autoBat then return end
        local tc=S.aTgt and S.aTgt.Character local mc=LP.Character if not tc or not mc then return end
        local th=tc:FindFirstChild("HumanoidRootPart") local mh=mc:FindFirstChild("HumanoidRootPart")
        local hum=mc:FindFirstChildOfClass("Humanoid") if not th or not mh or not hum then return end
        if hum.WalkSpeed~=50 then hum.WalkSpeed=50 end
        local tool=getEq() if not tool then return end
        local dist=(mh.Position-th.Position).Magnitude
        local fp=(th.CFrame*CFrame.new(0,0,-4)).Position
        if dist>5 then hum:MoveTo(Vector3.new(fp.X,mh.Position.Y,fp.Z))
        else mh.CFrame=CFrame.lookAt(mh.Position,Vector3.new(th.Position.X,mh.Position.Y,th.Position.Z)) swing(tool,th) end
    end)
end)

